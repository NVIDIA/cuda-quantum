// A straight-line, bounded-unitary kernel with an adjacent inverse pair (x, x)
// and a pair of mergeable rotations, so phase-folding has something to do while
// preserving the unitary.

func.func @kern() {
  %cst = arith.constant 1.000000e+00 : f64
  %q = quake.alloca !quake.veq<2>
  %r0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %r1 = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  quake.h %r0 : (!quake.ref) -> ()
  quake.x [%r0] %r1 : (!quake.ref, !quake.ref) -> ()
  quake.rz (%cst) %r1 : (f64, !quake.ref) -> ()
  quake.rz (%cst) %r1 : (f64, !quake.ref) -> ()
  quake.x %r0 : (!quake.ref) -> ()
  quake.x %r0 : (!quake.ref) -> ()
  cc.return
}
