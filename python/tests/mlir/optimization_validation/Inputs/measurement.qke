// A kernel with a measurement: outside the bounded-unitary domain. The CLI must
// fail closed with an `unsupported-domain` status and a nonzero exit code.

func.func @kern() {
  %q = quake.alloca !quake.veq<1>
  %r = quake.extract_ref %q[0] : (!quake.veq<1>) -> !quake.ref
  quake.h %r : (!quake.ref) -> ()
  %m = quake.mz %r : (!quake.ref) -> !quake.measure
  cc.return
}
