// Structurally invalid IR: extract_ref indexes past the end of a veq<1>. The
// input verify gate must reject this as `invalid-request`, not mistake it for an
// internal infrastructure error.

func.func @kernel() {
  %q = quake.alloca !quake.veq<1>
  %r = quake.extract_ref %q[5] : (!quake.veq<1>) -> !quake.ref
  cc.return
}
