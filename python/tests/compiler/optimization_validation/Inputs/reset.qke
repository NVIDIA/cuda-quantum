// A kernel containing a reset. Outside the bounded-unitary domain, so the
// validator must fail closed with an `unsupported-domain` status.

func.func @kernel() {
  %q = quake.alloca !quake.veq<1>
  %r = quake.extract_ref %q[0] : (!quake.veq<1>) -> !quake.ref
  quake.reset %r : (!quake.ref) -> ()
  cc.return
}
