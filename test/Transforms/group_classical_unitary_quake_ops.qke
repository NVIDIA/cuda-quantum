// RUN: cudaq-opt --group-classical-unitary-quake-ops %s | FileCheck %s

// group-classical-unitary-quake-ops: when multiple ops are ready, schedule
// classical ops, then unitaries, then measurements/resets, then other quake
// ops, then by original block index.

// Classical chain hoisted; independent unitaries on two wires cluster per wire.
func.func @cluster_classical_then_unitaries() {
  %w0 = quake.null_wire
  %w1 = quake.null_wire
  %c = arith.constant 0 : i32
  %w0h = quake.h %w0 : (!quake.wire) -> !quake.wire
  %d = arith.addi %c, %c : i32
  %w1x = quake.x %w1 : (!quake.wire) -> !quake.wire
  %w0x = quake.x %w0h : (!quake.wire) -> !quake.wire
  %e = arith.addi %d, %d : i32
  %w1h = quake.h %w1x : (!quake.wire) -> !quake.wire
  %f = arith.addi %e, %e : i32
  quake.sink %w0x : !quake.wire
  quake.sink %w1h : !quake.wire
  return
}

// CHECK-LABEL: func.func @cluster_classical_then_unitaries
// CHECK: arith.constant
// CHECK-NEXT: arith.addi
// CHECK-NEXT: arith.addi
// CHECK-NEXT: arith.addi
// CHECK-NEXT: quake.null_wire
// CHECK-NEXT: quake.h
// CHECK-NEXT: quake.x
// CHECK-NEXT: quake.null_wire
// CHECK-NEXT: quake.x
// CHECK-NEXT: quake.h
// CHECK-NEXT: quake.sink
// CHECK-NEXT: quake.sink
// CHECK-NEXT: return

// Classical before measure; unitary before measure on the same wire.
func.func @classical_before_measurement() {
  %w = quake.null_wire
  %c = arith.constant 0 : i32
  %d = arith.addi %c, %c : i32
  %w1 = quake.h %w : (!quake.wire) -> !quake.wire
  %bits, %w2 = quake.mz %w1 name "m" : (!quake.wire) -> (!quake.measure, !quake.wire)
  %e = arith.addi %d, %d : i32
  quake.sink %w2 : !quake.wire
  return
}

// CHECK-LABEL: func.func @classical_before_measurement
// CHECK: arith.constant
// CHECK-NEXT: arith.addi
// CHECK-NEXT: arith.addi
// CHECK-NEXT: quake.null_wire
// CHECK-NEXT: quake.h
// CHECK-NEXT: quake.mz
// CHECK-NEXT: quake.sink
// CHECK-NEXT: return

// Unitaries on one wire cluster before reset on an independent wire.
func.func @unitaries_before_reset() {
  %w0 = quake.null_wire
  %w1 = quake.null_wire
  %w0h = quake.h %w0 : (!quake.wire) -> !quake.wire
  %w1n = quake.reset %w1 : (!quake.wire) -> !quake.wire
  %w0x = quake.x %w0h : (!quake.wire) -> !quake.wire
  quake.sink %w0x : !quake.wire
  quake.sink %w1n : !quake.wire
  return
}

// CHECK-LABEL: func.func @unitaries_before_reset
// CHECK: quake.null_wire
// CHECK-NEXT: quake.h
// CHECK-NEXT: quake.x
// CHECK-NEXT: quake.null_wire
// CHECK-NEXT: quake.reset
// CHECK-NEXT: quake.sink
// CHECK-NEXT: quake.sink
// CHECK-NEXT: return
