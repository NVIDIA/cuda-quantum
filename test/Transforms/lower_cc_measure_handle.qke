// RUN: cudaq-opt -lower-cc-measure-handle %s | FileCheck %s
// RUN: cudaq-opt -lower-cc-measure-handle -convert-to-qir-api %s \
// RUN:   | FileCheck --check-prefix=QIR %s

// Single-qubit handle: !cc.measure_handle becomes i64 on both the
// `quake.mz` result and the `quake.discriminate` operand.
func.func @scalar_handle(%q: !quake.ref) -> i1 {
  %h = quake.mz %q name "h" : (!quake.ref) -> !cc.measure_handle
  %b = quake.discriminate %h : (!cc.measure_handle) -> i1
  return %b : i1
}

// CHECK-LABEL: func.func @scalar_handle(
// CHECK-SAME:    %[[VAL_0:.*]]: !quake.ref) -> i1 {
// CHECK:         %[[VAL_1:.*]] = quake.mz %[[VAL_0]] name "h" : (!quake.ref) -> i64
// CHECK:         %[[VAL_2:.*]] = quake.discriminate %[[VAL_1]] : (i64) -> i1
// CHECK:         return %[[VAL_2]] : i1
// CHECK:       }

// After the lowering pass, ConvertToQIRAPI bridges the i64 payload to the
// underlying `Result*` so the QIR call still typechecks: the measurement
// result is cast i64<-Result*, and discriminate's read input is cast
// !cc.ptr<i1><-i64.
// QIR-LABEL: func.func @scalar_handle(
// QIR:         %[[QIR_M:.*]] = call @__quantum__qis__mz__to__register({{.*}}) {{.*}} -> !cc.ptr<!llvm.struct<"Result", opaque>>
// QIR:         %[[QIR_I:.*]] = cc.cast %[[QIR_M]] : (!cc.ptr<!llvm.struct<"Result", opaque>>) -> i64
// QIR:         %[[QIR_P:.*]] = cc.cast %[[QIR_I]] : (i64) -> !cc.ptr<i1>
// QIR:         %[[QIR_B:.*]] = cc.load %[[QIR_P]] : !cc.ptr<i1>
// QIR:         return %[[QIR_B]] : i1

// Handles flowing through cc.alloca/cc.store/cc.load: the alloca's
// elementType attribute must be rewritten alongside the result pointer
// type so the printed IR is internally consistent.
func.func @handle_through_memory(%q: !quake.ref) -> i1 {
  %h = quake.mz %q name "m" : (!quake.ref) -> !cc.measure_handle
  %slot = cc.alloca !cc.measure_handle
  cc.store %h, %slot : !cc.ptr<!cc.measure_handle>
  %loaded = cc.load %slot : !cc.ptr<!cc.measure_handle>
  %b = quake.discriminate %loaded : (!cc.measure_handle) -> i1
  return %b : i1
}

// CHECK-LABEL: func.func @handle_through_memory(
// CHECK-SAME:    %[[VAL_0:.*]]: !quake.ref) -> i1 {
// CHECK:         %[[VAL_1:.*]] = quake.mz %[[VAL_0]] name "m" : (!quake.ref) -> i64
// CHECK:         %[[VAL_2:.*]] = cc.alloca i64
// CHECK:         cc.store %[[VAL_1]], %[[VAL_2]] : !cc.ptr<i64>
// CHECK:         %[[VAL_3:.*]] = cc.load %[[VAL_2]] : !cc.ptr<i64>
// CHECK:         %[[VAL_4:.*]] = quake.discriminate %[[VAL_3]] : (i64) -> i1
// CHECK:         return %[[VAL_4]] : i1
// CHECK:       }

// Function signatures and call sites that pass handles between device-only
// kernels are rewritten on both sides.
func.func private @consumer(!cc.measure_handle) -> i1
func.func @passes_handle(%q: !quake.ref) -> i1 {
  %h = quake.mz %q name "p" : (!quake.ref) -> !cc.measure_handle
  %b = func.call @consumer(%h) : (!cc.measure_handle) -> i1
  return %b : i1
}

// CHECK-LABEL: func.func private @consumer(i64) -> i1
// CHECK-LABEL: func.func @passes_handle(
// CHECK-SAME:    %[[VAL_0:.*]]: !quake.ref) -> i1 {
// CHECK:         %[[VAL_1:.*]] = quake.mz %[[VAL_0]] name "p" : (!quake.ref) -> i64
// CHECK:         %[[VAL_2:.*]] = call @consumer(%[[VAL_1]]) : (i64) -> i1
// CHECK:         return %[[VAL_2]] : i1
// CHECK:       }

// Handles inside aggregate types (cc.stdvec, cc.ptr).
func.func @handle_aggregates(%v: !cc.stdvec<!cc.measure_handle>,
                             %p: !cc.ptr<!cc.measure_handle>)
    -> (!cc.stdvec<!cc.measure_handle>, !cc.ptr<!cc.measure_handle>) {
  return %v, %p : !cc.stdvec<!cc.measure_handle>,
                  !cc.ptr<!cc.measure_handle>
}

// CHECK-LABEL: func.func @handle_aggregates(
// CHECK-SAME:    %[[VAL_0:.*]]: !cc.stdvec<i64>,
// CHECK-SAME:    %[[VAL_1:.*]]: !cc.ptr<i64>) -> (!cc.stdvec<i64>, !cc.ptr<i64>) {
// CHECK:         return %[[VAL_0]], %[[VAL_1]] : !cc.stdvec<i64>, !cc.ptr<i64>
// CHECK:       }

// Statically-sized handle arrays through cc.alloca / pointer arithmetic.
// The alloca's elementType attribute, the resulting pointer type, and the
// pointer arithmetic (compute_ptr) all need to be lowered consistently.
func.func @handle_static_array(%q: !quake.ref) -> i1 {
  %c0 = arith.constant 0 : i64
  %h = quake.mz %q name "h" : (!quake.ref) -> !cc.measure_handle
  %arr = cc.alloca !cc.array<!cc.measure_handle x 4>
  %slot = cc.compute_ptr %arr[%c0] : (!cc.ptr<!cc.array<!cc.measure_handle x 4>>, i64) -> !cc.ptr<!cc.measure_handle>
  cc.store %h, %slot : !cc.ptr<!cc.measure_handle>
  %loaded = cc.load %slot : !cc.ptr<!cc.measure_handle>
  %b = quake.discriminate %loaded : (!cc.measure_handle) -> i1
  return %b : i1
}

// CHECK-LABEL: func.func @handle_static_array(
// CHECK-SAME:    %[[VAL_0:.*]]: !quake.ref) -> i1 {
// CHECK:         %[[VAL_C0:.*]] = arith.constant 0 : i64
// CHECK:         %[[VAL_H:.*]] = quake.mz %[[VAL_0]] name "h" : (!quake.ref) -> i64
// CHECK:         %[[VAL_ARR:.*]] = cc.alloca !cc.array<i64 x 4>
// CHECK:         %[[VAL_SLOT:.*]] = cc.compute_ptr %[[VAL_ARR]][%[[VAL_C0]]] : (!cc.ptr<!cc.array<i64 x 4>>, i64) -> !cc.ptr<i64>
// CHECK:         cc.store %[[VAL_H]], %[[VAL_SLOT]] : !cc.ptr<i64>
// CHECK:         %[[VAL_L:.*]] = cc.load %[[VAL_SLOT]] : !cc.ptr<i64>
// CHECK:         %[[VAL_B:.*]] = quake.discriminate %[[VAL_L]] : (i64) -> i1
// CHECK:         return %[[VAL_B]] : i1
// CHECK:       }

// Dynamically-sized handle arrays. Same shape as the static case, but the
// alloca and pointer types use `!cc.array<T x ?>`, exercising the
// unknown-size branch of the array converter.
func.func @handle_dynamic_array(%q: !quake.ref, %n: i64) -> i1 {
  %c0 = arith.constant 0 : i64
  %h = quake.mz %q name "h" : (!quake.ref) -> !cc.measure_handle
  %arr = cc.alloca !cc.measure_handle[%n : i64]
  %slot = cc.compute_ptr %arr[%c0] : (!cc.ptr<!cc.array<!cc.measure_handle x ?>>, i64) -> !cc.ptr<!cc.measure_handle>
  cc.store %h, %slot : !cc.ptr<!cc.measure_handle>
  %loaded = cc.load %slot : !cc.ptr<!cc.measure_handle>
  %b = quake.discriminate %loaded : (!cc.measure_handle) -> i1
  return %b : i1
}

// CHECK-LABEL: func.func @handle_dynamic_array(
// CHECK-SAME:    %[[VAL_0:.*]]: !quake.ref, %[[VAL_N:.*]]: i64) -> i1 {
// CHECK:         %[[VAL_C0:.*]] = arith.constant 0 : i64
// CHECK:         %[[VAL_H:.*]] = quake.mz %[[VAL_0]] name "h" : (!quake.ref) -> i64
// CHECK:         %[[VAL_ARR:.*]] = cc.alloca i64{{\[}}%[[VAL_N]] : i64]
// CHECK:         %[[VAL_SLOT:.*]] = cc.compute_ptr %[[VAL_ARR]][%[[VAL_C0]]] : (!cc.ptr<!cc.array<i64 x ?>>, i64) -> !cc.ptr<i64>
// CHECK:         cc.store %[[VAL_H]], %[[VAL_SLOT]] : !cc.ptr<i64>
// CHECK:         %[[VAL_L:.*]] = cc.load %[[VAL_SLOT]] : !cc.ptr<i64>
// CHECK:         %[[VAL_B:.*]] = quake.discriminate %[[VAL_L]] : (i64) -> i1
// CHECK:         return %[[VAL_B]] : i1
// CHECK:       }

// A function that touches no handle types must round-trip unchanged. This
// guards against the converter accidentally rewriting unrelated CC
// container types when no handle is present.
func.func private @takes_int_vec(!cc.stdvec<i64>, !cc.ptr<i64>) -> !cc.stdvec<i64>
func.func @no_handle(%v: !cc.stdvec<i64>, %p: !cc.ptr<i64>) -> !cc.stdvec<i64> {
  %r = func.call @takes_int_vec(%v, %p) : (!cc.stdvec<i64>, !cc.ptr<i64>) -> !cc.stdvec<i64>
  return %r : !cc.stdvec<i64>
}

// CHECK-LABEL: func.func private @takes_int_vec(!cc.stdvec<i64>, !cc.ptr<i64>) -> !cc.stdvec<i64>
// CHECK-LABEL: func.func @no_handle(
// CHECK-SAME:    %[[VAL_0:.*]]: !cc.stdvec<i64>,
// CHECK-SAME:    %[[VAL_1:.*]]: !cc.ptr<i64>) -> !cc.stdvec<i64> {
// CHECK:         %[[VAL_R:.*]] = call @takes_int_vec(%[[VAL_0]], %[[VAL_1]]) : (!cc.stdvec<i64>, !cc.ptr<i64>) -> !cc.stdvec<i64>
// CHECK:         return %[[VAL_R]] : !cc.stdvec<i64>
// CHECK:       }

// `cc.indirect_callable` (and `cc.callable`) carry a function-type
// signature whose inputs and results may name `!cc.measure_handle`. The
// pass must recurse into that signature so the callable's declared type
// stays in sync with the post-lowering call-site result; otherwise
// `cc.call_indirect_callable` rejects the module with "result type
// mismatch". Models the CUDA-QX `memory_circuit.cpp` round-trip via
// `code::stabilizer_round`.
func.func @indirect_handle(%ic: !cc.indirect_callable<(!quake.veq<?>) -> !cc.stdvec<!cc.measure_handle>>,
                           %qv: !quake.veq<?>) -> !cc.stdvec<!cc.measure_handle> {
  %r = cc.call_indirect_callable %ic, %qv : (!cc.indirect_callable<(!quake.veq<?>) -> !cc.stdvec<!cc.measure_handle>>, !quake.veq<?>) -> !cc.stdvec<!cc.measure_handle>
  return %r : !cc.stdvec<!cc.measure_handle>
}

// CHECK-LABEL: func.func @indirect_handle(
// CHECK-SAME:    %[[VAL_0:.*]]: !cc.indirect_callable<(!quake.veq<?>) -> !cc.stdvec<i64>>,
// CHECK-SAME:    %[[VAL_1:.*]]: !quake.veq<?>) -> !cc.stdvec<i64> {
// CHECK:         %[[VAL_R:.*]] = cc.call_indirect_callable %[[VAL_0]], %[[VAL_1]] : (!cc.indirect_callable<(!quake.veq<?>) -> !cc.stdvec<i64>>, !quake.veq<?>) -> !cc.stdvec<i64>
// CHECK:         return %[[VAL_R]] : !cc.stdvec<i64>
// CHECK:       }

// `cc.callable` (the in-module callable wrapper) carries the same kind
// of `FunctionType` payload as `cc.indirect_callable`; verify the same
// recursion applies to a handle-typed callable signature.
func.func @callable_handle(%c: !cc.callable<(!quake.ref) -> !cc.measure_handle>) {
  return
}

// CHECK-LABEL: func.func @callable_handle(
// CHECK-SAME:    %[[VAL_0:.*]]: !cc.callable<(!quake.ref) -> i64>) {
// CHECK:         return
// CHECK:       }
