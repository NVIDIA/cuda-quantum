// RUN: cudaq-opt -factor-quantum-alloc -memtoreg -canonicalize %s \
// RUN: | FileCheck %s

func.func private @callee(!quake.veq<?>, f32)

func.func @test() {
  %0 = quake.alloca !quake.veq<2>
  %1 = arith.constant 1.0 : f32
  %2 = quake.relax_size %0 : (!quake.veq<2>) -> !quake.veq<?>
  call @callee(%2, %1) : (!quake.veq<?>, f32) -> ()
  quake.dealloc %0 : !quake.veq<2>
  return
}

// CHECK-LABEL:   func.func @test() {
// CHECK:           %[[VAL_1:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[VAL_3:.*]] = quake.extract_ref %[[VAL_1]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[VAL_4:.*]] = quake.unwrap %[[VAL_3]] : (!quake.ref) -> !quake.wire
// CHECK:           quake.sink %[[VAL_4]] : !quake.wire
// CHECK:           %[[VAL_5:.*]] = quake.extract_ref %[[VAL_1]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[VAL_6:.*]] = quake.unwrap %[[VAL_5]] : (!quake.ref) -> !quake.wire
// CHECK:           quake.sink %[[VAL_6]] : !quake.wire
// CHECK:           return
// CHECK:         }
