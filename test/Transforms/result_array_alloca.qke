// RUN: cudaq-opt --convert-to-qir-api %s | FileCheck %s

func.func @test_measure_alloca() attributes {"cudaq-kernel"} {
  %c3 = arith.constant 3 : i64
  %buf = cc.alloca !quake.measure[%c3 : i64]
  return
}

// CHECK-LABEL:   func.func @test_measure_alloca() attributes {"cudaq-kernel", "qir-api"} {
// CHECK:           %[[VAL_0:.*]] = arith.constant 3 : i64
// CHECK:           %[[VAL_1:.*]] = call @__quantum__rt__result_array_create_1d(%[[VAL_0]]) : (i64) -> !cc.ptr<!llvm.struct<"Array", opaque>>
// CHECK:           return
// CHECK:         }
