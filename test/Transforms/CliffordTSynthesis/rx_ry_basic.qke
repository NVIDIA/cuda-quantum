// REQUIRES: clifford-t-synthesis

// RUN: cudaq-opt --clifford-t-synthesis='epsilon=1e-3' %s | \
// RUN:   FileCheck %s --implicit-check-not='quake.r{{[xyz1]}}'

// Rx and Ry lower to a Clifford sandwich around an inner Rz, which the
// greedy driver then re-fires on. The result must contain no surviving
// rotation ops and a minimum of T gates per function.
// 15 is a safety floor robust to gridsynth variance.
// The actual T-count at epsilon=1e-3 is on the order of dozens.

func.func @rx_pi_over_4() {
  %q = quake.alloca !quake.ref
  %a = arith.constant 0.7853981633974483 : f64
  quake.rx (%a) %q : (f64, !quake.ref) -> ()
  return
}

// CHECK-LABEL: func.func @rx_pi_over_4
// CHECK:         quake.alloca
// CHECK-COUNT-15: quake.t

func.func @ry_pi_over_4() {
  %q = quake.alloca !quake.ref
  %a = arith.constant 0.7853981633974483 : f64
  quake.ry (%a) %q : (f64, !quake.ref) -> ()
  return
}

// CHECK-LABEL: func.func @ry_pi_over_4
// CHECK:         quake.alloca
// CHECK-COUNT-15: quake.t
