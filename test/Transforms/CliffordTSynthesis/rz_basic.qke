// REQUIRES: clifford-t-synthesis

// RUN: cudaq-opt --clifford-t-synthesis='epsilon=1e-3' %s | \
// RUN:   FileCheck %s --implicit-check-not='quake.r{{[xyz1]}}'

// gridsynth output is stochastic. We assert only structural invariants.
// No rotation ops survive, and at least one T gate is emitted (a non-trivial
// constant angle always requires T-count > 0).

func.func @rz_pi_over_4() {
  %q = quake.alloca !quake.ref
  %a = arith.constant 0.7853981633974483 : f64
  quake.rz (%a) %q : (f64, !quake.ref) -> ()
  return
}

// CHECK-LABEL: func.func @rz_pi_over_4
// CHECK:         quake.alloca
// CHECK:         quake.t
