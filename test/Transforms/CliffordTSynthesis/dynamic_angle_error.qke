// REQUIRES: clifford-t-synthesis

// RUN: cudaq-opt --clifford-t-synthesis='epsilon=1e-3' \
// RUN:   -verify-diagnostics %s

// With the default --on-dynamic-angle=error, a non-constant rotation angle
// must produce a diagnostic naming the option that controls this behaviour.

func.func @dyn(%a: f64) {
  %q = quake.alloca !quake.ref
  // expected-error @+1 {{rotation angle is not a compile-time constant}}
  quake.rz (%a) %q : (f64, !quake.ref) -> ()
  return
}
