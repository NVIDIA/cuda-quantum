// CHECK:         %[[VAL_2:.*]] = load i32, ptr %[[VAL_0]]
// CHECK:         %[[VAL_3:.*]] = tail call { ptr, i64 } @__nvqpp__mlirgen__test_0(i32 %[[VAL_2]])
// CHECK:         tail call void @__nvqpp_cleanup_arrays()
