// CHECK:         %[[VAL_15:.*]] = insertvalue { ptr, i64 } undef, ptr %[[VAL_13]], 0
// CHECK:         %[[VAL_11]] = insertvalue { ptr, i64 } %[[VAL_15]], i64 %[[VAL_12]], 1
