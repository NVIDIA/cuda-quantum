// CHECK:         store ptr %[[VAL_2]], ptr %[[VAL_6]]
// CHECK:         %[[VAL_7:.*]] = call { ptr, i64 } @hybridLaunchKernel(ptr nonnull @test_2.kernelName, ptr nonnull @test_2.thunk, ptr nonnull %[[VAL_3]], i64 24, i64 0, ptr nonnull %[[VAL_4]])
