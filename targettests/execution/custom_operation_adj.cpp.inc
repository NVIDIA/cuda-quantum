// Source template for per-target execution checks.
// Individual tests are generated by lit.cfg.py for each target.

#include <cudaq.h>

CUDAQ_REGISTER_OPERATION(custom_s, 1, 0,
                         {1, 0, 0, std::complex<double>{0.0, 1.0}})

CUDAQ_REGISTER_OPERATION(custom_s_adj, 1, 0,
                         {1, 0, 0, std::complex<double>{0.0, -1.0}})

__qpu__ void kernel() {
  cudaq::qubit q;
  h(q);
  custom_s<cudaq::adj>(q);
  custom_s_adj(q);
  h(q);
  mz(q);
}

int main() {
  auto counts = cudaq::sample(kernel);
  for (auto &[bits, count] : counts) {
    printf("%s\n", bits.data());
  }
  return 0;
}

// CHECK: 1
