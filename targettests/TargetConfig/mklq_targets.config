# Validate the Apple Silicon MKL-Q simulator target configs.

# REQUIRES: mklq-backend,mklq-apple-silicon-target

# RUN: test -f %cudaq_src_dir/runtime/nvqir/mklq/mklq-cpu.yml
# RUN: test -f %cudaq_src_dir/runtime/nvqir/mklq/mklq-metal.yml
# RUN: test -f %cudaq_target_dir/mklq-cpu.yml
# RUN: test -f %cudaq_target_dir/mklq-metal.yml
# RUN: FileCheck %s --check-prefix=CPU < %cudaq_src_dir/runtime/nvqir/mklq/mklq-cpu.yml
# RUN: FileCheck %s --check-prefix=METAL < %cudaq_src_dir/runtime/nvqir/mklq/mklq-metal.yml
# RUN: FileCheck %s --check-prefix=CPU < %cudaq_target_dir/mklq-cpu.yml
# RUN: FileCheck %s --check-prefix=METAL < %cudaq_target_dir/mklq-metal.yml

# CPU: name: mklq-cpu
# CPU: nvqir-simulation-backend: mklq_cpu
# CPU: CUDAQ_SIMULATION_SCALAR_FP64
# CPU: MKLQ_APPLE_SILICON_CPU_BASELINE

# METAL: name: mklq-metal
# METAL: resident fp32 Metal single-target/two-target/probability-fill kernels
# METAL: cost-gated resident marginal or full-register probability fills for partial-register sampling
# METAL: a resident measurement-collapse path
# METAL: nvqir-simulation-backend: mklq_metal
# METAL: CUDAQ_SIMULATION_SCALAR_FP64
# METAL: MKLQ_METAL_EXPERIMENTAL_CPU_ORACLE
