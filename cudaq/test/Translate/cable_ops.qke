// BASE:         %[[VAL_6:.*]] = tail call ptr @__quantum__rt__array_create_1d(i32 8, i64 1)
// BASE:         %[[VAL_7:.*]] = tail call ptr @__quantum__rt__array_get_element_ptr_1d(ptr %[[VAL_6]], i64 0)
// BASE:         store ptr %[[VAL_1]], ptr %[[VAL_7]], align 8
// BASE:         %[[VAL_8:.*]] = tail call ptr @__quantum__rt__array_concatenate(ptr %[[VAL_4]], ptr %[[VAL_6]])
// BASE:         %[[VAL_9:.*]] = tail call ptr @__quantum__rt__array_create_1d(i32 8, i64 1)
// BASE:         %[[VAL_10:.*]] = tail call ptr @__quantum__rt__array_get_element_ptr_1d(ptr %[[VAL_9]], i64 0)
// BASE:         store ptr %[[VAL_3]], ptr %[[VAL_10]], align 8
// BASE:         %[[VAL_11:.*]] = tail call ptr @__quantum__rt__array_concatenate(ptr %[[VAL_8]], ptr %[[VAL_9]])
// BASE:         %[[VAL_12:.*]] = tail call ptr @__quantum__rt__array_create_1d(i32 8, i64 1)
// BASE:         %[[VAL_13:.*]] = tail call ptr @__quantum__rt__array_get_element_ptr_1d(ptr %[[VAL_12]], i64 0)
// BASE:         store ptr %[[VAL_2]], ptr %[[VAL_13]], align 8
// BASE:         %[[VAL_14:.*]] = tail call ptr @__quantum__rt__array_concatenate(ptr %[[VAL_11]], ptr %[[VAL_12]])
// BASE:         ret ptr %[[VAL_14]]
// BASE:       }

