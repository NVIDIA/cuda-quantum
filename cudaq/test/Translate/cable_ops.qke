// BASE:         tail call void @__quantum__qis__cnot__body(ptr %[[VAL_1]], ptr %[[VAL_3]])
// BASE:         %[[VAL_4:.*]] = tail call ptr @__quantum__rt__array_create_1d(i32 8, i64 1)
// BASE:         %[[VAL_5:.*]] = tail call ptr @__quantum__rt__array_get_element_ptr_1d(ptr %[[VAL_4]], i64 0)
