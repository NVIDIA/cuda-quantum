    ^bb0(%arg1: i64):
      %7 = quake.extract_ref %4[%arg1] : (!quake.veq<?>, i64) -> !quake.ref
      quake.x %7 : (!quake.ref) -> ()
      cc.continue %arg1 : i64
    } step {
    ^bb0(%arg1: i64):
      %7 = arith.addi %arg1, %c1_i64 : i64
      cc.continue %7 : i64
    } {invariant}
    quake.dealloc %4 : !quake.veq<?>
