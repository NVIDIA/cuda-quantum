// callable_closure(instantiate_callable) folds to the captured value; the size
// (4) is then constant, the loop unrolls, and the unused lambda is removed.

// CHECK-LABEL: define void @__nvqpp__mlirgen__kernel0..0x7c72351ce620(i64
// CHECK-SAME:    %[[VAL_0:.*]]) local_unnamed_addr {
// CHECK:         %[[VAL_1:.*]] = tail call ptr @__quantum__rt__qubit_allocate_array(i64 4)
// CHECK:         %[[VAL_2:.*]] = tail call ptr @__quantum__rt__array_get_element_ptr_1d(ptr %[[VAL_1]], i64 0)
// CHECK:         %[[VAL_3:.*]] = load ptr, ptr %[[VAL_2]], align 8
// CHECK:         tail call void @__quantum__qis__x(ptr %[[VAL_3]])
// CHECK:         %[[VAL_4:.*]] = tail call ptr @__quantum__rt__array_get_element_ptr_1d(ptr %[[VAL_1]], i64 1)
// CHECK:         %[[VAL_5:.*]] = load ptr, ptr %[[VAL_4]], align 8
// CHECK:         tail call void @__quantum__qis__x(ptr %[[VAL_5]])
// CHECK:         %[[VAL_6:.*]] = tail call ptr @__quantum__rt__array_get_element_ptr_1d(ptr %[[VAL_1]], i64 2)
// CHECK:         %[[VAL_7:.*]] = load ptr, ptr %[[VAL_6]], align 8
// CHECK:         tail call void @__quantum__qis__x(ptr %[[VAL_7]])
// CHECK:         %[[VAL_8:.*]] = tail call ptr @__quantum__rt__array_get_element_ptr_1d(ptr %[[VAL_1]], i64 3)
// CHECK:         %[[VAL_9:.*]] = load ptr, ptr %[[VAL_8]], align 8
// CHECK:         tail call void @__quantum__qis__x(ptr %[[VAL_9]])
// CHECK:         tail call void @__quantum__rt__qubit_release_array(ptr %[[VAL_1]])
// CHECK:         ret void
// CHECK:       }

// The lambda is no longer referenced and must be eliminated.
// CHECK-NOT: @__nvqpp__callable.thunk.lambda.0
