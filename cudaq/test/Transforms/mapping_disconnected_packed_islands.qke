// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_packed_islands.txt) placement=auto     search=none'  %s | FileCheck --implicit-check-not=quake.swap %s
// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_packed_islands.txt) placement=auto     search=sabre' %s | FileCheck --implicit-check-not=quake.swap %s
// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_packed_islands.txt) placement=greedy   search=none'  %s | FileCheck --implicit-check-not=quake.swap %s
// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_packed_islands.txt) placement=greedy   search=sabre' %s | FileCheck --implicit-check-not=quake.swap %s
// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_packed_islands.txt) placement=greedy   search=none'  %s | CircuitCheck --up-to-mapping %s
// RUN: not cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_packed_islands.txt) placement=identity' %s 2>&1 | FileCheck --check-prefix=IDENTITY %s

quake.wire_set @wires[2147483647]

func.func @packed_islands() {
  %v0 = quake.borrow_wire @wires[0] : !quake.wire
  %v1 = quake.borrow_wire @wires[1] : !quake.wire
  %v2 = quake.borrow_wire @wires[2] : !quake.wire
  %v3 = quake.borrow_wire @wires[3] : !quake.wire
  %v4 = quake.borrow_wire @wires[4] : !quake.wire
  %v5 = quake.borrow_wire @wires[5] : !quake.wire
  %v6 = quake.borrow_wire @wires[6] : !quake.wire
  %v7 = quake.borrow_wire @wires[7] : !quake.wire
  %v8 = quake.borrow_wire @wires[8] : !quake.wire
  %v9 = quake.borrow_wire @wires[9] : !quake.wire
  %a:2 = quake.x [%v0] %v1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %b:2 = quake.x [%a#1] %v2 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %c:2 = quake.x [%v3] %v4 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %d:2 = quake.x [%c#1] %v5 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %e:2 = quake.x [%v6] %v7 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %f:2 = quake.x [%v8] %v9 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  quake.return_wire %b#0 : !quake.wire
  quake.return_wire %a#0 : !quake.wire
  quake.return_wire %b#1 : !quake.wire
  quake.return_wire %d#0 : !quake.wire
  quake.return_wire %c#0 : !quake.wire
  quake.return_wire %d#1 : !quake.wire
  quake.return_wire %e#0 : !quake.wire
  quake.return_wire %e#1 : !quake.wire
  quake.return_wire %f#0 : !quake.wire
  quake.return_wire %f#1 : !quake.wire
  return
}

// CHECK-LABEL:   func.func @packed_islands() attributes {mapping_reorder_idx = [6, 5, 4, 9, 8, 7, 1, 0, 2, 3], mapping_v2p = [7, 6, 5, 11, 10, 9, 2, 1, 3, 4]} {
// CHECK:           %[[VAL_0:.*]] = quake.borrow_wire @mapped_wireset[7] : !quake.wire
// CHECK:           %[[VAL_1:.*]] = quake.borrow_wire @mapped_wireset[6] : !quake.wire
// CHECK:           %[[VAL_2:.*]] = quake.borrow_wire @mapped_wireset[5] : !quake.wire
// CHECK:           %[[VAL_3:.*]] = quake.borrow_wire @mapped_wireset[11] : !quake.wire
// CHECK:           %[[VAL_4:.*]] = quake.borrow_wire @mapped_wireset[10] : !quake.wire
// CHECK:           %[[VAL_5:.*]] = quake.borrow_wire @mapped_wireset[9] : !quake.wire
// CHECK:           %[[VAL_6:.*]] = quake.borrow_wire @mapped_wireset[2] : !quake.wire
// CHECK:           %[[VAL_7:.*]] = quake.borrow_wire @mapped_wireset[1] : !quake.wire
// CHECK:           %[[VAL_8:.*]] = quake.borrow_wire @mapped_wireset[3] : !quake.wire
// CHECK:           %[[VAL_9:.*]] = quake.borrow_wire @mapped_wireset[4] : !quake.wire
// CHECK:           %[[X_0:.*]]:2 = quake.x {{\[}}%[[VAL_0]]] %[[VAL_1]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_1:.*]]:2 = quake.x {{\[}}%[[X_0]]#1] %[[VAL_2]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_2:.*]]:2 = quake.x {{\[}}%[[VAL_3]]] %[[VAL_4]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_3:.*]]:2 = quake.x {{\[}}%[[X_2]]#1] %[[VAL_5]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_4:.*]]:2 = quake.x {{\[}}%[[VAL_6]]] %[[VAL_7]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_5:.*]]:2 = quake.x {{\[}}%[[VAL_8]]] %[[VAL_9]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)

// IDENTITY: cannot place two-qubit interaction between virtual qubits 4 and 5 on disconnected device topology
