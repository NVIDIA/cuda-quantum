// RUN: cudaq-opt -lambda-lifting -canonicalize -apply-op-specialization %s | FileCheck %s

func.func @test_caller() {
  %c8_i64 = arith.constant 8 : i64
  %0 = quake.alloca !quake.veq<8>
  %1 = cc.create_lambda {
   ^bb0(%arg0: !quake.veq<?>, %arg1: i64):
    %c1_i64 = arith.constant 1 : i64
    %c0_i64 = arith.constant 0 : i64
    %c4_i64 = arith.constant 4 : i64
    %10:2 = cc.loop while ((%arg2 = %c0_i64, %arg3 = %c0_i64) -> (i64, i64)) {
      %11 = arith.cmpi ult, %arg3, %c4_i64 : i64
      cc.condition %11(%arg2, %arg3 : i64, i64)
    } do {
      ^bb0(%arg2: i64, %arg3: i64):
        %21 = quake.extract_ref %arg0[%arg3] : (!quake.veq<?>, i64) -> !quake.ref
        quake.x %21 : (!quake.ref) -> ()
        %22 = arith.addi %arg2, %c1_i64 : i64
        cc.continue %22, %arg3 : i64, i64
    } step {
      ^bb0(%arg2: i64, %arg3: i64):
        %31 = arith.addi %arg3, %c1_i64 : i64
        cc.continue %arg2, %31 : i64, i64
    }
    cc.return
  } : !cc.callable<(!quake.veq<?>, i64) -> ()>
  %2 = quake.relax_size %0 : (!quake.veq<8>) -> !quake.veq<?>
  quake.apply<adj> %1 %2, %c8_i64 : (!quake.veq<?>, i64) -> ()
  return
}

// CHECK-LABEL: func.func @test_caller()
// CHECK-NOT:   quake.apply<adj>
// CHECK:       return
