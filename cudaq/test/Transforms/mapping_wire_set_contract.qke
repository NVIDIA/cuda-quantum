// RUN: cudaq-opt '--qubit-mapping=device=star(5,2) placement=greedy search=none' %s | FileCheck --implicit-check-not=backend --implicit-check-not=physical_name %s

quake.wire_set @wires[2147483647]

func.func @wire_set_contract() {
  %q0 = quake.borrow_wire @wires[0] : !quake.wire
  %q1 = quake.borrow_wire @wires[1] : !quake.wire
  %q2 = quake.borrow_wire @wires[2] : !quake.wire
  %0 = quake.h %q0 : (!quake.wire) -> !quake.wire
  %1:2 = quake.x [%0] %q1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %2:2 = quake.x [%1#0] %q2 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  quake.return_wire %2#0 : !quake.wire
  quake.return_wire %1#1 : !quake.wire
  quake.return_wire %2#1 : !quake.wire
  return
}

// CHECK: quake.wire_set @mapped_wireset[5] adjacency
// CHECK-LABEL: func.func @wire_set_contract
// CHECK: %[[Q0:.*]] = quake.borrow_wire @mapped_wireset[2]
// CHECK: %[[Q1:.*]] = quake.borrow_wire @mapped_wireset[0]
// CHECK: %[[Q2:.*]] = quake.borrow_wire @mapped_wireset[1]
// CHECK: %[[H:.*]] = quake.h %[[Q0]] : (!quake.wire) -> !quake.wire
// CHECK: quake.x [%[[H]]] %[[Q1]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK: quake.x [{{.*}}] %[[Q2]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
