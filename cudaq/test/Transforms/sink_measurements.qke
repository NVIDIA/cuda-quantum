// -----

func.func @stop_before_control_operand_alias() {
  %q = quake.alloca !quake.veq<2>
  %ctrl = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %target = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  %m = quake.mz %ctrl : (!quake.ref) -> !quake.measure
  quake.x [%ctrl] %target : (!quake.ref, !quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @stop_before_control_operand_alias() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           quake.x {{\[}}%[[EXTRACT_REF_0]]] %[[EXTRACT_REF_1]] : (!quake.ref, !quake.ref) -> ()
// CHECK:           return
// CHECK:         }

// -----

func.func @stop_before_quantum_result_that_may_alias() {
  %q = quake.alloca !quake.veq<2>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %q1 = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  %aliasable = quake.concat %q1 : (!quake.ref) -> !quake.veq<1>
  return
}

// CHECK-LABEL:   func.func @stop_before_quantum_result_that_may_alias() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           %[[CONCAT_0:.*]] = quake.concat %[[EXTRACT_REF_1]] : (!quake.ref) -> !quake.veq<1>
// CHECK:           return
// CHECK:         }

// -----

func.func @stop_before_later_measurement() {
  %q = quake.alloca !quake.veq<3>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<3>) -> !quake.ref
  %q1 = quake.extract_ref %q[1] : (!quake.veq<3>) -> !quake.ref
  %q2 = quake.extract_ref %q[2] : (!quake.veq<3>) -> !quake.ref
  %m0 = quake.mz %q0 : (!quake.ref) -> !quake.measure
  %m1 = quake.mz %q1 : (!quake.ref) -> !quake.measure
  quake.h %q2 : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @stop_before_later_measurement() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<3>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<3>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<3>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_2:.*]] = quake.extract_ref %[[ALLOCA_0]][2] : (!quake.veq<3>) -> !quake.ref
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           quake.h %[[EXTRACT_REF_2]] : (!quake.ref) -> ()
// CHECK:           %[[MZ_1:.*]] = quake.mz %[[EXTRACT_REF_1]] : (!quake.ref) -> !quake.measure
// CHECK:           return
// CHECK:         }

// -----

func.func @stop_before_region_op() {
  %true = arith.constant true
  %q = quake.alloca !quake.veq<2>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %q1 = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  cc.if(%true) {
    quake.h %q1 : (!quake.ref) -> ()
  }
  return
}

// CHECK-LABEL:   func.func @stop_before_region_op() {
// CHECK:           %[[CONSTANT_0:.*]] = arith.constant true
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           cc.if(%[[CONSTANT_0]]) {
// CHECK:             quake.h %[[EXTRACT_REF_1]] : (!quake.ref) -> ()
// CHECK:           }
// CHECK:           return
// CHECK:         }

// -----

func.func @stop_before_side_effecting_non_quake_op() {
  %byte = arith.constant 1 : i8
  %buffer = cc.alloca !cc.array<i8 x 1>
  %ptr = cc.cast %buffer : (!cc.ptr<!cc.array<i8 x 1>>) -> !cc.ptr<i8>
  %q = quake.alloca !quake.veq<2>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %q1 = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  cc.store %byte, %ptr : !cc.ptr<i8>
  quake.h %q1 : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @stop_before_side_effecting_non_quake_op() {
// CHECK:           %[[CONSTANT_0:.*]] = arith.constant 1 : i8
// CHECK:           %[[ALLOCA_0:.*]] = cc.alloca !cc.array<i8 x 1>
// CHECK:           %[[CAST_0:.*]] = cc.cast %[[ALLOCA_0]] : (!cc.ptr<!cc.array<i8 x 1>>) -> !cc.ptr<i8>
// CHECK:           %[[ALLOCA_1:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_1]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_1]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           cc.store %[[CONSTANT_0]], %[[CAST_0]] : !cc.ptr<i8>
// CHECK:           quake.h %[[EXTRACT_REF_1]] : (!quake.ref) -> ()
// CHECK:           return
// CHECK:         }
