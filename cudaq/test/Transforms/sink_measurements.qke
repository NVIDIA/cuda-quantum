func.func @stop_before_different_nonlocal_bases(%arg0: !quake.ref, %arg1: !quake.ref) {
  %m = quake.mz %arg0 : (!quake.ref) -> !quake.measure
  quake.h %arg1 : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @stop_before_different_nonlocal_bases(
