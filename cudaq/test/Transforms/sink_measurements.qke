func.func @stop_before_dynamic_index_operand(%idx: i64) {
  %q = quake.alloca !quake.veq<2>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %qx = quake.extract_ref %q[%idx] : (!quake.veq<2>, i64) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  quake.h %qx : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @stop_before_dynamic_index_operand(
// CHECK-SAME:      %[[ARG0:.*]]: i64) {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]]{{\[}}%[[ARG0]]] : (!quake.veq<2>, i64) -> !quake.ref
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           quake.h %[[EXTRACT_REF_1]] : (!quake.ref) -> ()
// CHECK:           return
// CHECK:         }

