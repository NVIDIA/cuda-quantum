// RUN: cudaq-opt --sink-measurements %s | FileCheck %s

func.func @sink_past_independent_local_refs() {
  %q = quake.alloca !quake.veq<3>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<3>) -> !quake.ref
  %q1 = quake.extract_ref %q[1] : (!quake.veq<3>) -> !quake.ref
  %q2 = quake.extract_ref %q[2] : (!quake.veq<3>) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  quake.h %q1 : (!quake.ref) -> ()
  quake.x %q2 : (!quake.ref) -> ()
  %bit = quake.discriminate %m : (!quake.measure) -> i1
  return
}

// CHECK-LABEL:   func.func @sink_past_independent_local_refs() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<3>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<3>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<3>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_2:.*]] = quake.extract_ref %[[ALLOCA_0]][2] : (!quake.veq<3>) -> !quake.ref
// CHECK:           quake.h %[[EXTRACT_REF_1]] : (!quake.ref) -> ()
// CHECK:           quake.x %[[EXTRACT_REF_2]] : (!quake.ref) -> ()
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           %[[DISCRIMINATE_0:.*]] = quake.discriminate %[[MZ_0]] : (!quake.measure) -> i1
// CHECK:           return
// CHECK:         }

// -----

func.func @sink_past_different_local_allocas() {
  %q0 = quake.alloca !quake.ref
  %q1 = quake.alloca !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  quake.h %q1 : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @sink_past_different_local_allocas() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.ref
// CHECK:           %[[ALLOCA_1:.*]] = quake.alloca !quake.ref
// CHECK:           quake.h %[[ALLOCA_1]] : (!quake.ref) -> ()
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[ALLOCA_0]] : (!quake.ref) -> !quake.measure
// CHECK:           return
// CHECK:         }

// -----

func.func @stop_before_later_extract_from_measured_veq() {
  %q = quake.alloca !quake.veq<2>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  %q1 = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  quake.h %q1 : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @stop_before_later_extract_from_measured_veq() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           quake.h %[[EXTRACT_REF_1]] : (!quake.ref) -> ()
// CHECK:           return
// CHECK:         }

// -----

func.func @sink_to_terminator() {
  %q = quake.alloca !quake.veq<2>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %q1 = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  quake.h %q1 : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @sink_to_terminator() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           quake.h %[[EXTRACT_REF_1]] : (!quake.ref) -> ()
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           return
// CHECK:         }

// -----

func.func @sink_past_memory_effect_free_classical_op() {
  %c0 = arith.constant 0 : i64
  %c1 = arith.constant 1 : i64
  %q = quake.alloca !quake.veq<2>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %q1 = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  %sum = arith.addi %c0, %c1 : i64
  quake.h %q1 : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @sink_past_memory_effect_free_classical_op() {
// CHECK:           %[[CONSTANT_0:.*]] = arith.constant 0 : i64
// CHECK:           %[[CONSTANT_1:.*]] = arith.constant 1 : i64
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[ADDI_0:.*]] = arith.addi %[[CONSTANT_0]], %[[CONSTANT_1]] : i64
// CHECK:           quake.h %[[EXTRACT_REF_1]] : (!quake.ref) -> ()
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           return
// CHECK:         }

// -----

func.func @stop_before_discriminate_user() {
  %q = quake.alloca !quake.veq<2>
  %q0 = quake.extract_ref %q[0] : (!quake.veq<2>) -> !quake.ref
  %q1 = quake.extract_ref %q[1] : (!quake.veq<2>) -> !quake.ref
  %m = quake.mz %q0 : (!quake.ref) -> !quake.measure
  %bit = quake.discriminate %m : (!quake.measure) -> i1
  quake.h %q1 : (!quake.ref) -> ()
  return
}

// CHECK-LABEL:   func.func @stop_before_discriminate_user() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<2>
// CHECK:           %[[EXTRACT_REF_0:.*]] = quake.extract_ref %[[ALLOCA_0]][0] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[EXTRACT_REF_1:.*]] = quake.extract_ref %[[ALLOCA_0]][1] : (!quake.veq<2>) -> !quake.ref
// CHECK:           %[[MZ_0:.*]] = quake.mz %[[EXTRACT_REF_0]] : (!quake.ref) -> !quake.measure
// CHECK:           %[[DISCRIMINATE_0:.*]] = quake.discriminate %[[MZ_0]] : (!quake.measure) -> i1
// CHECK:           quake.h %[[EXTRACT_REF_1]] : (!quake.ref) -> ()
// CHECK:           return
// CHECK:         }

