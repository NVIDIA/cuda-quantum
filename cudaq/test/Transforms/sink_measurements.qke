func.func @stop_before_nonlocal_same_base(%arg0: !quake.veq<2>) {
  %q0 = quake.extract_ref %arg0[0] : (!quake.veq<2>) -> !quake.ref
  %q1 = quake.extract_ref %arg0[1] : (!quake.veq<2>) -> !quake.ref
