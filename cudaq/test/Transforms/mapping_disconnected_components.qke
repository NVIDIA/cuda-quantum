// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_components.txt) placement=auto search=none' %s | FileCheck --implicit-check-not=quake.swap %s

quake.wire_set @wires[2147483647]

func.func @component_swapped() {
  %v0 = quake.borrow_wire @wires[0] : !quake.wire
  %v1 = quake.borrow_wire @wires[1] : !quake.wire
  %v2 = quake.borrow_wire @wires[2] : !quake.wire
  %v3 = quake.borrow_wire @wires[3] : !quake.wire
  %v4 = quake.borrow_wire @wires[4] : !quake.wire
  %a:2 = quake.x [%v0] %v1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %b:2 = quake.x [%a#0] %a#1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %c:2 = quake.x [%b#0] %b#1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %d:2 = quake.x [%v2] %v3 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  %e:2 = quake.x [%d#1] %v4 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  quake.return_wire %c#0 : !quake.wire
  quake.return_wire %c#1 : !quake.wire
  quake.return_wire %d#0 : !quake.wire
  quake.return_wire %e#0 : !quake.wire
  quake.return_wire %e#1 : !quake.wire
  return
}

// CHECK-LABEL:   func.func @component_swapped() attributes {mapping_reorder_idx = [3, 4, 0, 1, 2], mapping_v2p = [3, 4, 0, 1, 2]} {
// CHECK:           %[[BORROW_WIRE_0:.*]] = quake.borrow_wire @mapped_wireset[3] : !quake.wire
// CHECK:           %[[BORROW_WIRE_1:.*]] = quake.borrow_wire @mapped_wireset[4] : !quake.wire
// CHECK:           %[[BORROW_WIRE_2:.*]] = quake.borrow_wire @mapped_wireset[0] : !quake.wire
// CHECK:           %[[BORROW_WIRE_3:.*]] = quake.borrow_wire @mapped_wireset[1] : !quake.wire
// CHECK:           %[[BORROW_WIRE_4:.*]] = quake.borrow_wire @mapped_wireset[2] : !quake.wire
// CHECK:           %[[X_0:.*]]:2 = quake.x {{\[}}%[[BORROW_WIRE_0]]] %[[BORROW_WIRE_1]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_1:.*]]:2 = quake.x {{\[}}%[[X_0]]#0] %[[X_0]]#1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_2:.*]]:2 = quake.x {{\[}}%[[X_1]]#0] %[[X_1]]#1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_3:.*]]:2 = quake.x {{\[}}%[[BORROW_WIRE_2]]] %[[BORROW_WIRE_3]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
// CHECK:           %[[X_4:.*]]:2 = quake.x {{\[}}%[[X_3]]#1] %[[BORROW_WIRE_4]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
