// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_pair.txt) placement=auto     search=none'  %s | FileCheck --implicit-check-not=quake.swap %s
// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_pair.txt) placement=auto     search=sabre' %s | FileCheck --implicit-check-not=quake.swap %s
// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_pair.txt) placement=greedy   search=none'  %s | FileCheck --implicit-check-not=quake.swap %s
// RUN: cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_pair.txt) placement=greedy   search=sabre' %s | FileCheck --implicit-check-not=quake.swap %s
// RUN: not cudaq-opt '--qubit-mapping=device=file(%S/mapping_disconnected_pair.txt) placement=identity'  %s 2>&1 | FileCheck --check-prefix=IDENTITY %s

quake.wire_set @wires[2147483647]

func.func @bell_pair() {
  %q0 = quake.borrow_wire @wires[0] : !quake.wire
  %q1 = quake.borrow_wire @wires[1] : !quake.wire
  %0 = quake.h %q0 : (!quake.wire) -> !quake.wire
  %1:2 = quake.x [%0] %q1 : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)
  quake.return_wire %1#0 : !quake.wire
  quake.return_wire %1#1 : !quake.wire
  return
}

// CHECK-LABEL:   func.func @bell_pair() attributes {mapping_reorder_idx = [0, 1], mapping_v2p = [5, 6]} {
// CHECK:           %[[BORROW_WIRE_0:.*]] = quake.borrow_wire @mapped_wireset[5] : !quake.wire
// CHECK:           %[[BORROW_WIRE_1:.*]] = quake.borrow_wire @mapped_wireset[6] : !quake.wire
// CHECK:           %[[H_0:.*]] = quake.h %[[BORROW_WIRE_0]] : (!quake.wire) -> !quake.wire
// CHECK:           %[[X_0:.*]]:2 = quake.x {{\[}}%[[H_0]]] %[[BORROW_WIRE_1]] : (!quake.wire, !quake.wire) -> (!quake.wire, !quake.wire)

// IDENTITY: cannot place two-qubit interaction between virtual qubits 0 and 1 on disconnected device topology
