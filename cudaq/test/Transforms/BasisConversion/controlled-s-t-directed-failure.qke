// RUN: not cudaq-opt --basis-conversion="basis=h,s,t,rx,ry,rz,x,y,z,x(1)" %s 2>&1 | FileCheck %s

// CHECK: failed to legalize operation 'quake.s'
func.func @two_control_s(%ctrl0: !quake.ref, %ctrl1: !quake.ref,
                         %target: !quake.ref) {
  quake.s [%ctrl0, %ctrl1] %target
      : (!quake.ref, !quake.ref, !quake.ref) -> ()
  return
}
