func.func @boolOutput(%arg0 : !cc.stdvec<i1>) attributes {
  "cudaq-entrypoint", "cudaq-kernel", no_this
} {
  cc.device_call @produceBits(%arg0) : (!cc.stdvec<i1>) -> () {
    by_ref_vec_arg_indices = array<i64: 0>
  }
  return
}

