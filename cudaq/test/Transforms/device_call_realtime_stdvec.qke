// CHECK:           %[[LOAD_1:.*]] = cc.load %[[ALLOCA_1]] : !cc.ptr<!cc.ptr<i8>>
// CHECK:           %[[CAST_1:.*]] = cc.cast %[[LOAD_1]] : (!cc.ptr<i8>) -> !cc.ptr<!cc.array<i8 x ?>>
// CHECK:           %[[STDVEC_DATA_0:.*]] = cc.stdvec_data %[[ARG0]] : (!cc.stdvec<!cc.measure_handle>) -> !cc.ptr<!cc.array<!cc.measure_handle x ?>>
// CHECK:           %[[CAST_2:.*]] = cc.cast %[[LOAD_1]] : (!cc.ptr<i8>) -> !cc.ptr<i64>
// CHECK:           cc.store %[[STDVEC_SIZE_0]], %[[CAST_2]] : !cc.ptr<i64>
// CHECK:           %[[LOOP_0:.*]] = cc.loop while ((%[[VAL_1:.*]] = %[[CONSTANT_4]]) -> (i64)) {
// CHECK:             %[[CMPI_1:.*]] = arith.cmpi slt, %[[VAL_1]], %[[STDVEC_SIZE_0]] : i64
// CHECK:             cc.condition %[[CMPI_1]](%[[VAL_1]] : i64)
// CHECK:           } do {
// CHECK:           ^bb0(%[[VAL_2:.*]]: i64):
// CHECK:             %[[COMPUTE_PTR_0:.*]] = cc.compute_ptr %[[STDVEC_DATA_0]]{{\[}}%[[VAL_2]]] : (!cc.ptr<!cc.array<!cc.measure_handle x ?>>, i64) -> !cc.ptr<!cc.measure_handle>
// CHECK:             %[[LOAD_2:.*]] = cc.load %[[COMPUTE_PTR_0]] : !cc.ptr<!cc.measure_handle>
// CHECK:             %[[DISCRIMINATE_0:.*]] = quake.discriminate %[[LOAD_2]] : (!cc.measure_handle) -> i1
// CHECK:             %[[ADDI_2:.*]] = arith.addi %[[VAL_2]], %[[CONSTANT_6]] : i64
// CHECK:             %[[CAST_3:.*]] = cc.cast unsigned %[[DISCRIMINATE_0]] : (i1) -> i8
// CHECK:             %[[COMPUTE_PTR_1:.*]] = cc.compute_ptr %[[CAST_1]]{{\[}}%[[ADDI_2]]] : (!cc.ptr<!cc.array<i8 x ?>>, i64) -> !cc.ptr<i8>
// CHECK:             cc.store %[[CAST_3]], %[[COMPUTE_PTR_1]] : !cc.ptr<i8>
// CHECK:             cc.continue %[[VAL_2]] : i64
// CHECK:           } step {
// CHECK:           ^bb0(%[[VAL_3:.*]]: i64):
