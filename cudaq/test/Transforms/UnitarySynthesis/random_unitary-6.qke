    %2 = quake.extract_ref %0[2] : (!quake.veq<4>) -> !quake.ref
    %3 = quake.extract_ref %0[1] : (!quake.veq<4>) -> !quake.ref
    %4 = quake.extract_ref %0[0] : (!quake.veq<4>) -> !quake.ref
    quake.custom_unitary_constant @__nvqpp__mlirgen__op16_generator_4.rodata %1, %2, %3, %4 : (!quake.ref, !quake.ref, !quake.ref, !quake.ref) -> ()
    return
  }
