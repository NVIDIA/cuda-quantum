    %3 = quake.extract_ref %0[2] : (!quake.veq<5>) -> !quake.ref
    %4 = quake.extract_ref %0[1] : (!quake.veq<5>) -> !quake.ref
    %5 = quake.extract_ref %0[0] : (!quake.veq<5>) -> !quake.ref
    quake.custom_unitary_constant @__nvqpp__mlirgen__op32_generator_5.rodata %1, %2, %3, %4, %5 : (!quake.ref, !quake.ref, !quake.ref, !quake.ref, !quake.ref) -> ()
    return
  }
