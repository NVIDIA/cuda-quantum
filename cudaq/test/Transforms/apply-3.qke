// RUN: cudaq-opt -lambda-lifting -canonicalize -apply-op-specialization %s -o %t && FileCheck %s < %t && FileCheck --check-prefix=LIFTED %s < %t && FileCheck --check-prefix=ADJOINT %s < %t

func.func @cr(%arg : !quake.veq<?>) {
  quake.t %arg : (!quake.veq<?>) -> ()
  quake.h %arg : (!quake.veq<?>) -> ()
  quake.x %arg : (!quake.veq<?>) -> ()
  return
}

func.func @entry_point() {
  %0 = quake.alloca !quake.veq<3>
  %1 = quake.relax_size %0 : (!quake.veq<3>) -> !quake.veq<?>
  %2 = cc.create_lambda {
   ^bb0(%arg: !quake.veq<?>):
    func.call @cr(%arg) : (!quake.veq<?>) -> ()
    cc.return
  } : !cc.callable<(!quake.veq<?>) -> ()>
  cc.call_callable %2, %1 : (!cc.callable<(!quake.veq<?>) -> ()>, !quake.veq<?>) -> ()
  quake.apply <adj> %2 %1 : (!quake.veq<?>) -> ()
  return
}

// CHECK-LABEL:   func.func @cr(
// CHECK-SAME:                  %[[ARG0:.*]]: !quake.veq<?>) {

// CHECK-LABEL:   func.func @entry_point() {
// CHECK:           %[[ALLOCA_0:.*]] = quake.alloca !quake.veq<3>
// CHECK:           %[[RELAX_SIZE_0:.*]] = quake.relax_size %[[ALLOCA_0]] : (!quake.veq<3>) -> !quake.veq<?>
// CHECK:           %[[INSTANTIATE_CALLABLE_0:.*]] = cc.instantiate_callable @__nvqpp__callable.thunk.lambda.0() : () -> !cc.callable<(!quake.veq<?>) -> ()>
// CHECK:           call @__nvqpp__callable.thunk.lambda.0(%[[INSTANTIATE_CALLABLE_0]], %[[RELAX_SIZE_0]]) : (!cc.callable<(!quake.veq<?>) -> ()>, !quake.veq<?>) -> ()
// CHECK:           %[[INSTANTIATE_CALLABLE_1:.*]] = cc.instantiate_callable @__nvqpp__callable.thunk.lambda.0.adj() : () -> !cc.callable<(!quake.veq<?>) -> ()>
// CHECK:           call @__nvqpp__callable.thunk.lambda.0.adj(%[[INSTANTIATE_CALLABLE_1]], %[[RELAX_SIZE_0]]) : (!cc.callable<(!quake.veq<?>) -> ()>, !quake.veq<?>) -> ()
// CHECK:           return
// CHECK:         }

//===----------------------------------------------------------------------===//
// Check the autogenerated content
// Lambda lifted and specialized functions
//===----------------------------------------------------------------------===//

// LIFTED-LABEL:   func.func private @__nvqpp__callable.thunk.lambda.0(
// LIFTED-SAME:      %[[ARG0:.*]]: !cc.callable<(!quake.veq<?>) -> ()>,
// LIFTED-SAME:      %[[ARG1:.*]]: !quake.veq<?>) attributes {"cudaq-kernel"} {
// LIFTED:           call @__nvqpp__lifted.lambda.0(%[[ARG1]]) : (!quake.veq<?>) -> ()
// LIFTED:           return
// LIFTED:         }

// LIFTED-LABEL:   func.func private @__nvqpp__lifted.lambda.0(
// LIFTED-SAME:      %[[ARG0:.*]]: !quake.veq<?>) attributes {"cudaq-kernel"} {
// LIFTED:           call @cr(%[[ARG0]]) : (!quake.veq<?>) -> ()
// LIFTED:           return
// LIFTED:         }

// ADJOINT-LABEL:   func.func private @cr.adj(
// ADJOINT-SAME:      %[[ARG0:.*]]: !quake.veq<?>) {
// ADJOINT:           quake.x %[[ARG0]] : (!quake.veq<?>) -> ()
// ADJOINT:           quake.h %[[ARG0]] : (!quake.veq<?>) -> ()
// ADJOINT:           quake.t<adj> %[[ARG0]] : (!quake.veq<?>) -> ()
// ADJOINT:           return
// ADJOINT:         }

// ADJOINT-LABEL:   func.func private @__nvqpp__lifted.lambda.0.adj(
// ADJOINT-SAME:      %[[ARG0:.*]]: !quake.veq<?>) {
// ADJOINT:           call @cr.adj(%[[ARG0]]) : (!quake.veq<?>) -> ()
// ADJOINT:           return
// ADJOINT:         }

// ADJOINT-LABEL:   func.func private @__nvqpp__callable.thunk.lambda.0.adj(
// ADJOINT-SAME:      %[[ARG0:.*]]: !cc.callable<(!quake.veq<?>) -> ()>,
// ADJOINT-SAME:      %[[ARG1:.*]]: !quake.veq<?>) {
// ADJOINT:           call @__nvqpp__lifted.lambda.0.adj(%[[ARG1]]) : (!quake.veq<?>) -> ()
// ADJOINT:           return
// ADJOINT:         }
