// RUN: cudaq-opt --clifford-t-synthesis='epsilon=1e-3' %s | \
// RUN:   FileCheck %s --implicit-check-not='quake.r{{[xyz1]}}'

// gridsynth output is stochastic. We assert only structural invariants.
// No rotation ops survive. The Clifford+T sequence is outlined into a
// per-angle helper at the top of the module and the kernel calls it.
// At epsilon=1e-3 the decomposition emits dozens of T gates.
// 15 is a safety floor robust to gridsynth variance.

func.func @rz_pi_over_4() {
  %q = quake.alloca !quake.ref
  %a = arith.constant 0.7853981633974483 : f64
  quake.rz (%a) %q : (f64, !quake.ref) -> ()
  return
}

// CHECK-LABEL: func.func private @__cliffordt_rz_
// CHECK-COUNT-15: quake.t

// CHECK-LABEL: func.func @rz_pi_over_4
// CHECK:         quake.alloca
// CHECK:         call @__cliffordt_rz_
