// RUN: cudaq-opt -verify-diagnostics -pass-pipeline='builtin.module(distributed-device-call{realtime=1})' %s

func.func @pointerLengthKernel(%arg0: !cc.ptr<i32>, %arg1: i64, %arg2: i32) -> i32 attributes {"cudaq-entrypoint", "cudaq-kernel", no_this} {
  // expected-error @+1 {{'cc.device_call' op realtime device_call lowering does not support raw pointer arguments}}
  %0 = cc.device_call @sumIntArray(%arg0, %arg1, %arg2) : (!cc.ptr<i32>, i64, i32) -> i32
  return %0 : i32
}

func.func private @sumIntArray(!cc.ptr<i32>, i64, i32) -> i32 attributes {"cudaq-devicecall"}
