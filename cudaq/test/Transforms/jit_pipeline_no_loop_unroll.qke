// RUN: cudaq-opt --pass-pipeline="builtin.module(hw-jit-prep-pipeline{no-loop-unroll=true},jit-deploy-pipeline{no-loop-unroll=true})" %s | FileCheck --check-prefix=PRESERVE %s
// RUN: cudaq-opt --pass-pipeline="builtin.module(hw-jit-prep-pipeline,jit-deploy-pipeline)" %s | FileCheck --check-prefix=UNROLL %s

func.func @__nvqpp__mlirgen__function_loop_payload_stress() -> i64 attributes {"cudaq-entrypoint", "cudaq-kernel", no_this} {
  %c0_i64 = arith.constant 0 : i64
  %c1_i64 = arith.constant 1 : i64
  %c2_i64 = arith.constant 2 : i64
  %c4_i64 = arith.constant 4 : i64
  %q = quake.alloca !quake.veq<4>

  cc.loop while ((%pass = %c0_i64) -> (i64)) {
    %again = arith.cmpi slt, %pass, %c2_i64 : i64
    cc.condition %again(%pass : i64)
  } do {
  ^bb0(%pass: i64):
    cc.loop while ((%i = %c0_i64) -> (i64)) {
      %again = arith.cmpi slt, %i, %c4_i64 : i64
      cc.condition %again(%i : i64)
    } do {
    ^bb0(%i: i64):
      %ref = quake.extract_ref %q[%i] : (!quake.veq<4>, i64) -> !quake.ref
      quake.x %ref : (!quake.ref) -> ()
      cc.continue %i : i64
    } step {
    ^bb0(%i: i64):
      %next = arith.addi %i, %c1_i64 : i64
      cc.continue %next : i64
    }
    cc.continue %pass : i64
  } step {
  ^bb0(%pass: i64):
    %next = arith.addi %pass, %c1_i64 : i64
    cc.continue %next : i64
  }

  cc.loop while ((%i = %c0_i64) -> (i64)) {
    %again = arith.cmpi slt, %i, %c4_i64 : i64
    cc.condition %again(%i : i64)
  } do {
  ^bb0(%i: i64):
    %ref = quake.extract_ref %q[%i] : (!quake.veq<4>, i64) -> !quake.ref
    quake.x %ref : (!quake.ref) -> ()
    %next = arith.addi %i, %c1_i64 : i64
    cc.continue %next : i64
  } step {
  ^bb0(%i: i64):
    cc.continue %i : i64
  }

  %meas = quake.mz %q : (!quake.veq<4>) -> !cc.stdvec<!quake.measure>
  %bits = quake.discriminate %meas : (!cc.stdvec<!quake.measure>) -> !cc.stdvec<i1>
  %result = call @__nvqpp_cudaqConvertToInteger(%bits) : (!cc.stdvec<i1>) -> i64
  return %result : i64
}

func.func private @__nvqpp_cudaqConvertToInteger(!cc.stdvec<i1>) -> i64

// PRESERVE-LABEL: func.func @__nvqpp__mlirgen__function_loop_payload_stress
// PRESERVE:         cc.loop while
// PRESERVE:         cc.loop while
// PRESERVE:         cc.loop while
// PRESERVE:         quake.mz

// UNROLL-LABEL: func.func @__nvqpp__mlirgen__function_loop_payload_stress
// UNROLL-NOT:     cc.loop
// UNROLL:         quake.mz
